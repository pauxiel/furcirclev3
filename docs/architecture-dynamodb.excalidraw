      "containerId": null,
      "lineHeight": 1.25
    },
    {
      "type": "text",
      "id": "dd3_content",
      "x": 804, "y": 988,
      "width": 346, "height": 150,
      "text": "SK: PLAN#2026-01\n    PLAN#2026-02\n    PLAN#2026-03\n    PLAN#2026-04  ← sorts as string!\n\nISO 8601 YYYY-MM sorts lexicographically\n= chronologically. No date parsing needed.\n\nbegins_with PLAN# → full history in order.\nLatest plan: descending scan, take first.",
      "originalText": "SK: PLAN#2026-01\n    PLAN#2026-02\n    PLAN#2026-03\n    PLAN#2026-04  ← sorts as string!\n\nISO 8601 YYYY-MM sorts lexicographically\n= chronologically. No date parsing needed.\n\nbegins_with PLAN# → full history in order.\nLatest plan: descending scan, take first.",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#94a3b8",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
