    {
      "type": "text",
      "id": "gsi1_content",
      "x": 32, "y": 722,
      "width": 446, "height": 168,
      "text": "Owner → Dogs:\n  GSI1PK=OWNER#userId, GSI1SK begins_with DOG#\n\nOwner → Bookings (by status):\n  GSI1PK=OWNER#userId\n  GSI1SK begins_with BOOKING#upcoming#\n\nOwner → Threads:\n  GSI1PK=OWNER#userId, GSI1SK begins_with THREAD#\n\nOwner → Notifications:\n  GSI1PK=OWNER#userId, GSI1SK begins_with NOTIF#",
      "originalText": "Owner → Dogs:\n  GSI1PK=OWNER#userId, GSI1SK begins_with DOG#\n\nOwner → Bookings (by status):\n  GSI1PK=OWNER#userId\n  GSI1SK begins_with BOOKING#upcoming#\n\nOwner → Threads:\n  GSI1PK=OWNER#userId, GSI1SK begins_with THREAD#\n\nOwner → Notifications:\n  GSI1PK=OWNER#userId, GSI1SK begins_with NOTIF#",
      "fontSize": 10,
