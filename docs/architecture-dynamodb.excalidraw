    {
      "type": "text",
      "id": "dd3_title",
      "x": 804, "y": 966,
      "width": 346, "height": 18,
      "text": "Plan SK is chronologically sortable",
      "originalText": "Plan SK is chronologically sortable",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 650009,
      "version": 1,
      "versionNonce": 650010,
      "isDeleted": false,
