    {
      "type": "text",
      "id": "dd4_title",
      "x": 1190, "y": 966,
      "width": 358, "height": 18,
      "text": "Rating embedded in GSI3SK",
      "originalText": "Rating embedded in GSI3SK",
      "fontSize": 12,
