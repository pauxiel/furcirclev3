    {
      "type": "text",
      "id": "gsi3_title",
      "x": 1012, "y": 700,
      "width": 536, "height": 18,
      "text": "GSI3 — Provider Type Listing  (sorted by rating)",
      "originalText": "GSI3 — Provider Type Listing  (sorted by rating)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#6d28d9",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
