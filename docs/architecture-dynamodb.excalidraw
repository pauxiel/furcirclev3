      "id": "dd2_title",
      "x": 418, "y": 966,
      "width": 346, "height": 18,
      "text": "Messages under Thread partition",
      "originalText": "Messages under Thread partition",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
