{
  "name": "furbeta",
  "version": "1.0.0",
  "description": "FurCircle serverless backend — AI dog wellness plans",
  "main": "handler.js",
  "scripts": {
    "test": "jest --runInBand --testPathPattern=tests/lib",
    "test:integration": "jest --runInBand --testPathPattern=tests/integration",
    "test:e2e": "jest --runInBand --testPathPattern=tests/e2e",
    "test:all": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "env:load": "ts-node scripts/load-env.ts --stage dev"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.0.0",
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/client-sfn": "^3.0.0",
    "@aws-sdk/client-sns": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "axios": "^1.15.0",
    "dotenv": "^17.4.2",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/axios": "^0.9.36",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.27.7",
    "jest": "^29.0.0",
    "serverless-iam-roles-per-function": "^3.2.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.serverless/"
    ]
  }
}
